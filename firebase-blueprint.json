{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "A collection of cron jobs",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["crond"] },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "type", "ownerId", "createdAt"]
    },
    "ProjectMember": {
      "title": "Project Member",
      "description": "Mapping of users to projects with roles",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "editor", "viewer"] },
        "userEmail": { "type": "string" }
      },
      "required": ["projectId", "userId", "role"]
    },
    "Job": {
      "title": "Cron Job",
      "description": "A specific task to be executed",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "name": { "type": "string" },
        "cronExp": { "type": "string" },
        "type": { "type": "string", "enum": ["http", "shell", "php"] },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "number" }
      },
      "required": ["projectId", "name", "type", "content", "status", "createdAt"]
    },
    "JobLog": {
      "title": "Job Execution Log",
      "description": "Record of a job execution",
      "type": "object",
      "properties": {
        "jobId": { "type": "string" },
        "jobName": { "type": "string" },
        "triggerTime": { "type": "number" },
        "duration": { "type": "number" },
        "status": { "type": "string", "enum": ["success", "error"] },
        "output": { "type": "string" }
      },
      "required": ["jobId", "jobName", "triggerTime", "status"]
    },
    "ProjectFile": {
      "title": "Project File",
      "description": "Virtual file or folder for the framework environment",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "name": { "type": "string" },
        "path": { "type": "string" },
        "type": { "type": "string", "enum": ["file", "folder"] },
        "content": { "type": "string" },
        "parentId": { "type": "string" },
        "updatedAt": { "type": "number" }
      },
      "required": ["projectId", "name", "path", "type", "parentId", "updatedAt"]
    },
    "StatelessService": {
      "title": "Stateless Service",
      "description": "PHP web service endpoint",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "name": { "type": "string" },
        "route": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "number" }
      },
      "required": ["projectId", "name", "route", "content", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Projects"
    },
    "/projects/{projectId}/members/{memberId}": {
      "schema": "ProjectMember",
      "description": "Project membership and roles"
    },
    "/projects/{projectId}/framework-files/{fileId}": {
      "schema": "ProjectFile",
      "description": "Virtual filesystem for framework entry"
    },
    "/projects/{projectId}/jobs/{jobId}": {
      "schema": "Job",
      "description": "Jobs within a project"
    },
    "/projects/{projectId}/jobs/{jobId}/logs/{logId}": {
      "schema": "JobLog",
      "description": "Logs for a specific job"
    },
    "/projects/{projectId}/stateless-services/{serviceId}": {
      "schema": "StatelessService",
      "description": "Stateless PHP services"
    }
  }
}
